# ============================================
# Construct — Environment Variables
# ============================================
# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# --- Wallet ---
# Generate a NEW wallet for testnet. Do NOT reuse a mainnet key.
# Quick: node -e "console.log(require('ethers').Wallet.createRandom().privateKey)"
DEPLOYER_PRIVATE_KEY=

# --- 0G Chain (Galileo Testnet) ---
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_CHAIN_ID=16602

# --- 0G ChainScan (contract verification) ---
ZG_CHAINSCAN_API_KEY=